@model IEnumerable<ASP.NETCore_Exercise10.Models.Aircraft>
@{
    ViewData["Title"] = "Catalog";
}

<section class="page-hero">
    <div class="container">
        <h1>Aircraft Catalog</h1>
        <p>Browse our full fleet. Click any aircraft for the complete spec sheet.</p>
    </div>
</section>

<main class="container" style="padding-top: 1rem; padding-bottom: 4rem;">

    @if (User.Identity!.IsAuthenticated)
    {
        <div class="mb-3">
            <a asp-action="Create" class="hero-btn" style="font-size:0.9rem; padding:0.6rem 1.4rem;">+ Add New Aircraft</a>
        </div>
    }

    <section class="catalog-section">
        <div class="table-responsive">
            <table class="table align-middle catalog-table">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Product #</th>
                        <th>Name</th>
                        <th>Model</th>
                        <th>Description</th>
                        <th>Pax Max</th>
                        <th>Typical Seating</th>
                        <th>Cargo D3</th>
                        <th>Max Pallets</th>
                        <th>Water Vol.</th>
                        <th>Range</th>
                        <th>MMO</th>
                        <th>Max Ramp Wt.</th>
                        <th>Max T/O Wt.</th>
                        <th>Max Land. Wt.</th>
                        <th>Max Fuel</th>
                        <th>Overall Len.</th>
                        <th>Cabin Len.</th>
                        <th>Fuselage W.</th>
                        <th>Max Cabin W.</th>
                        <th>Wingspan</th>
                        <th>Height</th>
                        <th>Track</th>
                        <th>Wheelbase</th>
                        <th class="text-end">&nbsp;</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@item.ImageUrl" alt="@item.Name"
                                     style="width:80px; height:55px; object-fit:cover; border-radius:0.4rem;" />
                            </td>
                            <td><span class="product-code">@item.ProductNumber</span></td>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Model</td>
                            <td style="max-width:160px; white-space:normal; font-size:0.85rem;">@item.Description</td>
                            <td>@item.PaxMaxSeating</td>
                            <td>@item.TypicalSeating</td>
                            <td>@item.CargoD3capacity</td>
                            <td>@item.MaxPalletNumber</td>
                            <td>@item.WaterVolume</td>
                            <td>@item.PerformanceRange</td>
                            <td>@item.Mmo</td>
                            <td>@item.MaxRampWeight</td>
                            <td>@item.MaxTakeOffWeight</td>
                            <td>@item.MaxLandingWeight</td>
                            <td>@item.MaxFuelCapacity</td>
                            <td>@item.OverallLength</td>
                            <td>@item.CabinLength</td>
                            <td>@item.FuselageWidth</td>
                            <td>@item.MaxCabinWidth</td>
                            <td>@item.WingSpan</td>
                            <td>@item.Height</td>
                            <td>@item.Track</td>
                            <td>@item.Wheelbase</td>
                            <td class="text-end" style="white-space:nowrap;">
                                <a class="more-link" asp-action="Details" asp-route-id="@item.Id">Details</a>
                                @if (User.Identity!.IsAuthenticated)
                                {
                                    <a class="more-link ms-1" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                    <a class="more-link ms-1" asp-action="Delete" asp-route-id="@item.Id" style="border-color:#e53e3e; color:#e53e3e;">Delete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</main>
