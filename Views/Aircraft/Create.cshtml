@model ASP.NETCore_Exercise10.Models.Aircraft
@{
    ViewData["Title"] = "Add Aircraft";
}

<section class="page-hero">
    <div class="container">
        <h1>Add New Aircraft</h1>
        <p>Fill in the details below to add a new aircraft to the catalog.</p>
    </div>
</section>

<main class="container" style="padding-top: 1rem; padding-bottom: 4rem;">
    <div class="detail-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h5 class="mb-3">Basic Info</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="ProductNumber" class="form-label"></label>
                    <input asp-for="ProductNumber" class="form-control" required />
                    <span asp-validation-for="ProductNumber" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Model" class="form-label"></label>
                    <input asp-for="Model" class="form-control" required />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ImageUrl" class="form-label"></label>
                    <input asp-for="ImageUrl" class="form-control" />
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mb-3">Capacity</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="PaxMaxSeating" class="form-label"></label>
                    <input asp-for="PaxMaxSeating" class="form-control" />
                    <span asp-validation-for="PaxMaxSeating" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TypicalSeating" class="form-label"></label>
                    <input asp-for="TypicalSeating" class="form-control" required />
                    <span asp-validation-for="TypicalSeating" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CargoD3capacity" class="form-label"></label>
                    <input asp-for="CargoD3capacity" class="form-control" />
                    <span asp-validation-for="CargoD3capacity" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MaxPalletNumber" class="form-label"></label>
                    <input asp-for="MaxPalletNumber" class="form-control" />
                    <span asp-validation-for="MaxPalletNumber" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="WaterVolume" class="form-label"></label>
                    <input asp-for="WaterVolume" class="form-control" />
                    <span asp-validation-for="WaterVolume" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mb-3">Performance</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="PerformanceRange" class="form-label"></label>
                    <input asp-for="PerformanceRange" class="form-control" required />
                    <span asp-validation-for="PerformanceRange" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Mmo" class="form-label"></label>
                    <input asp-for="Mmo" class="form-control" />
                    <span asp-validation-for="Mmo" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mb-3">Weights</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label asp-for="MaxRampWeight" class="form-label"></label>
                    <input asp-for="MaxRampWeight" class="form-control" />
                    <span asp-validation-for="MaxRampWeight" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="MaxTakeOffWeight" class="form-label"></label>
                    <input asp-for="MaxTakeOffWeight" class="form-control" />
                    <span asp-validation-for="MaxTakeOffWeight" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="MaxLandingWeight" class="form-label"></label>
                    <input asp-for="MaxLandingWeight" class="form-control" />
                    <span asp-validation-for="MaxLandingWeight" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="MaxFuelCapacity" class="form-label"></label>
                    <input asp-for="MaxFuelCapacity" class="form-control" />
                    <span asp-validation-for="MaxFuelCapacity" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mb-3">Dimensions</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="OverallLength" class="form-label"></label>
                    <input asp-for="OverallLength" class="form-control" />
                    <span asp-validation-for="OverallLength" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CabinLength" class="form-label"></label>
                    <input asp-for="CabinLength" class="form-control" />
                    <span asp-validation-for="CabinLength" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="FuselageWidth" class="form-label"></label>
                    <input asp-for="FuselageWidth" class="form-control" />
                    <span asp-validation-for="FuselageWidth" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MaxCabinWidth" class="form-label"></label>
                    <input asp-for="MaxCabinWidth" class="form-control" />
                    <span asp-validation-for="MaxCabinWidth" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="WingSpan" class="form-label"></label>
                    <input asp-for="WingSpan" class="form-control" />
                    <span asp-validation-for="WingSpan" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Height" class="form-label"></label>
                    <input asp-for="Height" class="form-control" />
                    <span asp-validation-for="Height" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Track" class="form-label"></label>
                    <input asp-for="Track" class="form-control" />
                    <span asp-validation-for="Track" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Wheelbase" class="form-label"></label>
                    <input asp-for="Wheelbase" class="form-control" />
                    <span asp-validation-for="Wheelbase" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Create Aircraft" class="hero-btn border-0" style="cursor:pointer;" />
                <a asp-action="Index" class="back-link">Cancel</a>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
