@model ASP.NETCore_Exercise10.Models.Aircraft
@{
    ViewData["Title"] = "Delete Aircraft";
}

<section class="page-hero">
    <div class="container">
        <h1>Delete Aircraft</h1>
        <p>You are about to permanently remove this aircraft from the catalog.</p>
    </div>
</section>

<main class="container" style="padding-top: 1rem; padding-bottom: 4rem;">

    <div class="detail-card row g-4 mb-4">
        <div class="col-md-5">
            <img src="@Model.ImageUrl" alt="@Model.Name" />
        </div>
        <div class="col-md-7 d-flex flex-column justify-content-center">
            <span class="product-number">@Model.ProductNumber</span>
            <h2 class="mb-1">@Model.Name</h2>
            <p class="text-muted mb-3">@Model.Model</p>
            <p>@Model.Description</p>
        </div>
    </div>

    <div class="alert alert-danger mb-4">
        <strong>Warning:</strong> This action cannot be undone. Are you sure you want to delete <strong>@Model.Name</strong>?
    </div>

    <form asp-action="Delete" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Yes, Delete" class="hero-btn border-0" style="cursor:pointer; background:#e53e3e; color:#fff;" />
        <a asp-action="Index" class="back-link">Cancel</a>
    </form>
</main>
