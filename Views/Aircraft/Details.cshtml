@model ASP.NETCore_Exercise10.Models.Aircraft
@{
    ViewData["Title"] = "Details";
}

<section class="page-hero">
    <div class="container">
        <span class="product-number">@Model.ProductNumber</span>
        <h1>@Model.Name</h1>
        <p>@Model.Description</p>
    </div>
</section>

<main class="container" style="padding-top: 1rem; padding-bottom: 4rem;">

    <div class="detail-card row g-4 mb-4">
        <div class="col-md-5">
            <img src="@Model.ImageUrl" alt="@Model.Name" />
        </div>
        <div class="col-md-7 d-flex flex-column justify-content-center">
            <h2 class="mb-1">@Model.Name</h2>
            <p class="text-muted mb-3">@Model.Model</p>
            <p>@Model.Description</p>
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="mt-3 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="hero-btn" style="font-size:0.9rem; padding:0.6rem 1.4rem;">Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="hero-btn" style="font-size:0.9rem; padding:0.6rem 1.4rem; background:#e53e3e; color:#fff;">Delete</a>
                </div>
            }
        </div>
    </div>

    <div class="spec-wrap mb-4">
        <table class="table spec-table">
            <tbody>
                <tr><th>Product Number</th><td>@Model.ProductNumber</td></tr>
                <tr><th>Model</th><td>@Model.Model</td></tr>
                <tr><th>Pax Max Seating</th><td>@Model.PaxMaxSeating</td></tr>
                <tr><th>Typical Seating</th><td>@Model.TypicalSeating</td></tr>
                <tr><th>Cargo D3 Capacity</th><td>@Model.CargoD3capacity</td></tr>
                <tr><th>Max Pallet Number</th><td>@Model.MaxPalletNumber</td></tr>
                <tr><th>Water Volume</th><td>@Model.WaterVolume</td></tr>
                <tr><th>Performance Range</th><td>@Model.PerformanceRange</td></tr>
                <tr><th>MMO</th><td>@Model.Mmo</td></tr>
                <tr><th>Max Ramp Weight</th><td>@Model.MaxRampWeight</td></tr>
                <tr><th>Max Take-off Weight</th><td>@Model.MaxTakeOffWeight</td></tr>
                <tr><th>Max Landing Weight</th><td>@Model.MaxLandingWeight</td></tr>
                <tr><th>Max Fuel Capacity</th><td>@Model.MaxFuelCapacity</td></tr>
                <tr><th>Overall Length</th><td>@Model.OverallLength</td></tr>
                <tr><th>Cabin Length</th><td>@Model.CabinLength</td></tr>
                <tr><th>Fuselage Width</th><td>@Model.FuselageWidth</td></tr>
                <tr><th>Max Cabin Width</th><td>@Model.MaxCabinWidth</td></tr>
                <tr><th>Wingspan</th><td>@Model.WingSpan</td></tr>
                <tr><th>Height</th><td>@Model.Height</td></tr>
                <tr><th>Track</th><td>@Model.Track</td></tr>
                <tr><th>Wheelbase</th><td>@Model.Wheelbase</td></tr>
            </tbody>
        </table>
    </div>

    <a asp-action="Index" class="back-link">&larr; Back to Catalog</a>
</main>
