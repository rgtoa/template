@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="error-center">
    <div>
        <h1 class="text-danger" style="font-size: 5rem; font-weight: 700; margin-bottom: 0;">500</h1>
        <h2 class="text-danger mb-3">Something went wrong</h2>
        <p class="text-muted mb-4">An unexpected error occurred while processing your request.</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-muted" style="font-size: 0.85rem;">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }
        <a asp-controller="Home" asp-action="Index" class="hero-btn d-inline-block mt-2">&larr; Back to Home</a>
    </div>
</div>
