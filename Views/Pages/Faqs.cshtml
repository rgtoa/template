@{
    ViewData["Title"] = "FAQs";
}

<section class="page-hero">
    <div class="container">
        <h1>Frequently Asked Questions</h1>
        <p>Common questions about our catalog and aircraft.</p>
    </div>
</section>

<main class="container" style="padding-top: 2rem; padding-bottom: 4rem;">

    <div class="accordion" id="faqAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button"
                        data-bs-toggle="collapse" data-bs-target="#faq1">
                    What is the Skyline Aircraft Catalog?
                </button>
            </h2>
            <div id="faq1" class="accordion-collapse collapse show"
                 data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    Skyline is a fictional aircraft specification catalog built for educational purposes.
                    It allows users to browse a full fleet of aircraft with detailed technical specs,
                    including seating capacity, range, weights, and dimensions.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse" data-bs-target="#faq2">
                    Are the aircraft and specifications real?
                </button>
            </h2>
            <div id="faq2" class="accordion-collapse collapse"
                 data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    No. All aircraft models, names, images, and specifications shown in this catalog
                    are entirely fictional and created for educational and demonstration purposes only.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse" data-bs-target="#faq3">
                    Do I need an account to browse the catalog?
                </button>
            </h2>
            <div id="faq3" class="accordion-collapse collapse"
                 data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    No. Anyone can browse the catalog and view aircraft details without logging in.
                    An account is only required to add, edit, or delete aircraft records.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse" data-bs-target="#faq4">
                    How do I add or edit aircraft in the catalog?
                </button>
            </h2>
            <div id="faq4" class="accordion-collapse collapse"
                 data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    Register for an account and log in. Once authenticated, you will see Edit, Delete,
                    and Add New Aircraft buttons throughout the catalog. All users are treated as
                    administrators with full access to manage records.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse" data-bs-target="#faq5">
                    What technology powers this site?
                </button>
            </h2>
            <div id="faq5" class="accordion-collapse collapse"
                 data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    This site is built with ASP.NET Core MVC (.NET 10), Entity Framework Core connected
                    to an Azure SQL database, ASP.NET Core Identity for authentication, and Bootstrap 5
                    for the responsive layout. Images are hosted on Azure Blob Storage.
                </div>
            </div>
        </div>

    </div>
</main>
