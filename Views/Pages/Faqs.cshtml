@{
    ViewData["Title"] = "About Page";
}

<!-- header portion of the faqs page with bootstrap container (makes responsive  easy) -->
<section class="page-hero">
    <div class="container">
        <h1>Frequently Asked Questions</h1>
        <p>
            Some of the most common questions we get about our catalog
            and our aircraft.
        </p>
    </div>
</section>

