@{
    ViewData["Title"] = "About";
}

<section class="page-hero">
    <div class="container">
        <h1>Meet the Team</h1>
        <p>The people behind the Skyline aircraft catalog.</p>
    </div>
</section>

<main class="container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <div class="row align-items-center g-5">
        <div class="col-md-5">
            <img src="https://storageaccount417815.blob.core.windows.net/images09/aboutpic.png"
                 alt="About Skyline" class="img-fluid rounded" style="border-radius:1rem !important;" />
        </div>
        <div class="col-md-7">
            <h2>Who We Are</h2>
            <p>
                Skyline is a fictional aircraft specification catalog built as part of a web development
                exercise. It showcases a full fleet of aircraft with detailed technical specifications,
                from short-haul regional jets to long-haul wide-body flagships.
            </p>
            <p>
                The catalog is powered by an Azure SQL database and built with ASP.NET Core MVC,
                featuring full CRUD operations for authenticated users, a dynamic carousel, and a
                responsive design inspired by modern airline websites.
            </p>
            <p>
                All aircraft models, images, and specifications displayed in this application are
                purely fictional and created for educational purposes only.
            </p>
            <p class="text-muted" style="font-size:0.9rem;">— Captain Rafael</p>
        </div>
    </div>
</main>
