@model IEnumerable<ASP.NETCore_Exercise10.Models.Aircraft>
@{
    ViewData["Title"] = "Home Page";
}

<!-- TOP ANNOUNCEMENT BAR (ONLY FOR HOMEPAGE) -->
<div class="top-banner">
    <div class="ticker">
        Welcome aboard! All images and information in this page are purely fictional and made for educational purposes only - Captain Rafael
    </div>
</div>

<div class="home-hero">
        <img class="hero-bg"
             src="https://storageaccount417815.blob.core.windows.net/images09/aircraftherobg.png"
             alt="" />
        <div class="hero-text-wrap">
            <div class="container">
                <h1 class="hero-title">
                    Find your comfort,<br />
                    every spec at a glance.
                </h1>
                <a asp-controller="Pages" asp-action="About" class="hero-btn">Learn more about us</a>
            </div>
        </div>
    </div>

<main class="container home-main">

    <div class="floating-card">
        <div id="heroCarousel" class="carousel slide hero-carousel" data-bs-ride="carousel">

            <div class="carousel-indicators">
                @{ int idx = 0; }
                @foreach (var item in Model)
                {
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@idx"
                            class="@(idx == 0 ? "active" : "")"
                            aria-label="Slide @(idx + 1)"></button>
                    idx++;
                }
            </div>

            <div class="carousel-inner">
                @{ bool first = true; }
                @foreach (var item in Model)
                {
                    <div class="carousel-item @(first ? "active" : "")">
                        <a asp-controller="Aircraft" asp-action="Details" asp-route-id="@item.Id">
                            <img src="@item.ImageUrl" class="d-block img-fluid" alt="@item.Name" />
                            <div class="carousel-caption">
                                <h5>@item.Name</h5>
                                <p>@item.Description</p>
                                <span class="slide-cta">Explore &rarr;</span>
                            </div>
                        </a>
                    </div>
                    first = false;
                }
            </div>

            <button class="carousel-control-prev" type="button"
                    data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button"
                    data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>

    <section id="catalog" class="catalog-section">
        <h2 class="mb-2">Aircraft Catalog</h2>
        <p class="text-muted mb-4">
            Browse our full family of aircraft. Click "More info" for the
            detailed spec sheet of each model.
        </p>

        @if (User.Identity!.IsAuthenticated)
        {
            <div class="mb-3">
                <a asp-controller="Aircraft" asp-action="Create" class="hero-btn" style="font-size:0.9rem; padding:0.6rem 1.4rem;">+ Add New Aircraft</a>
            </div>
        }

        <div class="table-responsive">
            <table class="table align-middle catalog-table">
                <thead>
                    <tr>
                        <th>Product #</th>
                        <th>Name</th>
                        <th>Model</th>
                        <th>Typical Seating</th>
                        <th>Range (km)</th>
                        <th class="text-end">&nbsp;</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="product-code">@item.ProductNumber</span></td>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Model</td>
                            <td>@item.TypicalSeating</td>
                            <td>@item.PerformanceRange</td>
                            <td class="text-end">
                                <a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="@item.Id">More info &rarr;</a>
                                @if (User.Identity!.IsAuthenticated)
                                {
                                    <a class="more-link ms-1" asp-controller="Aircraft" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                                    <a class="more-link ms-1" asp-controller="Aircraft" asp-action="Delete" asp-route-id="@item.Id" style="border-color:#e53e3e; color:#e53e3e;">Delete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</main>
