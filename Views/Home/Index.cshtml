@{
    ViewData["Title"] = "Home Page";
}

<!-- TOP ANNOUNCEMENT BAR (ONLY FOR HOMEPAGE) -->
<div class="top-banner">
    <div class="ticker">
        Welcome aboard! All images and information in this page are purely fictional and made for educational purposes only - Captain Rafael
    </div>
</div>

<div class="home-hero">

        <!-- added a background pic inspired by qatar airways website, generated by canva -->
        <img class="hero-bg"
             src="https://storageaccount417815.blob.core.windows.net/images09/aircraftherobg.png"
             alt="" />

        <!-- headline text -->
        <div class="hero-text-wrap">
            <div class="container">
                <h1 class="hero-title">
                    Find your comfort,<br />
                    every spec at a glance.
                </h1>
                <a asp-controller="Pages" asp-action="About" class="hero-btn">Learn more about us</a>
            </div>
        </div>
    </div>

<!-- main content here -->
<main class="container home-main">

    <!-- Floating white card holding the carousel -->
    <div class="floating-card">

        <div id="heroCarousel" class="carousel slide hero-carousel"
             data-bs-ride="carousel">

            <!-- little dots at the bottom as sliders -->
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
            </div>

            <div class="carousel-inner">

                <!-- slide 1 -->
                <div class="carousel-item active">
                    <a asp-controller="Aircraft" asp-action="Details" asp-route-id="10">
                        <img src="https://storageaccount417815.blob.core.windows.net/images09/aircraft10.png"
                             class="d-block img-fluid" alt="Skyhawk X 1000" />
                        <div class="carousel-caption">
                            <h5>Skyhawk X 1000</h5>
                            <p>Efficient short-haul flying for busy regional routes.</p>
                            <span class="slide-cta">Explore &rarr;</span>
                        </div>
                    </a>
                </div>

                <!-- slide 2 -->
                <div class="carousel-item">
                    <a asp-controller="Aircraft" asp-action="Details" asp-route-id="9">
                        <img src="https://storageaccount417815.blob.core.windows.net/images09/aircraft9.png"
                             class="d-block img-fluid" alt="TITAN 100" />
                        <div class="carousel-caption">
                            <h5>TITAN 100</h5>
                            <p>Our mid-range workhorse, balanced for range and payload.</p>
                            <span class="slide-cta">Explore &rarr;</span>
                        </div>
                    </a>
                </div>

                <!-- slide 3 -->
                <div class="carousel-item">
                    <a asp-controller="Aircraft" asp-action="Details" asp-route-id="8">
                        <img src="https://storageaccount417815.blob.core.windows.net/images09/aircraft8.png"
                             class="d-block img-fluid" alt="STARK 800" />
                        <div class="carousel-caption">
                            <h5>STARK 800</h5>
                            <p>Long-haul wide-body built for intercontinental comfort.</p>
                            <span class="slide-cta">Explore &rarr;</span>
                        </div>
                    </a>
                </div>

                <!-- slide 4 -->
                <div class="carousel-item">
                    <a asp-controller="Aircraft" asp-action="Details" asp-route-id="7">
                        <img src="https://storageaccount417815.blob.core.windows.net/images09/aircraft7.png"
                             class="d-block img-fluid" alt="Spyder 900" />
                        <div class="carousel-caption">
                            <h5>Spyder 900</h5>
                            <p>Flagship freighter / VIP platform with unmatched volume.</p>
                            <span class="slide-cta">Explore &rarr;</span>
                        </div>
                    </a>
                </div>

            </div>

            <!-- prev / next controls from bootstrap -->
            <button class="carousel-control-prev" type="button"
                    data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button"
                    data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
        
    <!-- aircraft catalog table here -->
    <section id="catalog" class="catalog-section">
        <h2 class="mb-2">Aircraft Catalog</h2>
        <p class="text-muted mb-4">
            Browse our full family of aircraft. Click "More info" for the
            detailed spec sheet of each model.
        </p>

        <!-- table-responsive wraps the table so it scrolls sideways
            on small screens instead of breaking the layout -->
        <div class="table-responsive">
            <table class="table align-middle catalog-table">
                <thead>
                    <tr>
                        <th>Product #</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Typical Seating</th>
                        <th>Range (km)</th>
                        <th class="text-end">&nbsp;</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="product-code">AL-700</span></td>
                        <td><strong>AeroLine 700</strong></td>
                        <td><span class="cat-badge cat-short">Short-haul</span></td>
                        <td>120</td>
                        <td>3,500</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="1">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">AL-800</span></td>
                        <td><strong>Albatroz 800</strong></td>
                        <td><span class="cat-badge cat-short">Short-haul</span></td>
                        <td>150</td>
                        <td>4,100</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="2">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">SF-300</span></td>
                        <td><strong>Starfleet 300</strong></td>
                        <td><span class="cat-badge cat-mid">Mid-range</span></td>
                        <td>180</td>
                        <td>5,800</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="3">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">AC-400</span></td>
                        <td><strong>Accent 400</strong></td>
                        <td><span class="cat-badge cat-mid">Mid-range</span></td>
                        <td>210</td>
                        <td>6,500</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="4">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">FL-500</span></td>
                        <td><strong>Falcon 500</strong></td>
                        <td><span class="cat-badge cat-regional">Regional</span></td>
                        <td>80</td>
                        <td>2,800</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="5">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">BM-600</span></td>
                        <td><strong>Batman 600</strong></td>
                        <td><span class="cat-badge cat-regional">Regional</span></td>
                        <td>95</td>
                        <td>3,200</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="6">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">SM-900</span></td>
                        <td><strong>Spyder 900</strong></td>
                        <td><span class="cat-badge cat-long">Long-haul</span></td>
                        <td>280</td>
                        <td>11,500</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="7">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">IM-800</span></td>
                        <td><strong>STARK 800</strong></td>
                        <td><span class="cat-badge cat-long">Long-haul</span></td>
                        <td>320</td>
                        <td>13,200</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="8">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">TH-100</span></td>
                        <td><strong>TITAN 100</strong></td>
                        <td><span class="cat-badge cat-freight">Freighter / VIP</span></td>
                        <td>40</td>
                        <td>9,800</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="9">More info &rarr;</a></td>
                    </tr>
                    <tr>
                        <td><span class="product-code">SH-1000</span></td>
                        <td><strong>Skyhawk X 1000</strong></td>
                        <td><span class="cat-badge cat-freight">Freighter / VIP</span></td>
                        <td>55</td>
                        <td>12,000</td>
                        <td class="text-end"><a class="more-link" asp-controller="Aircraft" asp-action="Details" asp-route-id="10">More info &rarr;</a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</main>
